{
  "name": "alpha-fitness",
  "productName": "Alpha Fitness",
  "private": true,
  "version": "0.1.1",
  "description": "Alpha Fitness Jampur — gym management",
  "main": "dist-electron/main.js",
  "type": "module",
  "author": {
    "name": "Alpha Fitness",
    "email": "noreply@alphafitness.local"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "icons": "node scripts/build-icon.mjs",
    "pack": "npm run build && electron-builder --win --publish never",
    "release": "npm run build && electron-builder --win --publish always",
    "postinstall": "electron-rebuild -f -w better-sqlite3 || true"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.0",
    "better-sqlite3": "^11.7.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^14.0.0",
    "ws": "^8.20.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.alphafitness.jampur",
    "productName": "Alpha Fitness",
    "directories": { "output": "release" },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "assets/build/icon.png", "to": "icon.png" },
      { "from": "assets/build/icon.ico", "to": "icon.ico" }
    ],
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "assets/build/icon.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Alpha Fitness",
      "uninstallDisplayName": "Alpha Fitness"
    },
    "publish": {
      "provider": "github",
      "owner": "hmseeb",
      "repo": "alpha-fitness",
      "releaseType": "release"
    }
  }
}
